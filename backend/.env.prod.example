APP_VERSION=0.1.0
APP_NAME=Auctions
DESCRIPTION=Auctions - backend service
AUTHOR=Anton Pavlov

APP_ENV=production
DEBUG=false
DEBUG_LEVEL=INFO

AUTH_SECRET_KEY=change_me_prod_auth_secret
AUTH_TOKEN_TTL_MINUTES=10080
DEFAULT_USER_ENABLED=true
DEFAULT_USER_NAME=Default User
DEFAULT_USER_EMAIL=demo@auctions.local
DEFAULT_USER_PASSWORD=change-me-demo

POSTGRES_HOST=db
POSTGRES_DB=auctions_pg
POSTGRES_USER=auctions_app
POSTGRES_PASSWORD=change_me_prod_strong_password
POSTGRES_PORT=5432
POSTGRES_HOST_AUTH_METHOD=md5

REDIS_URL=redis://redis:6379/0
AUCTION_EVENTS_STREAM=auction:events
AUCTION_SYNC_INTERVAL_SECONDS=300
AUCTION_SYNC_LIMIT=0
AUCTION_DETAIL_SYNC_ENABLED=true
AUCTION_DETAIL_SYNC_LIMIT=25

TBANKROT_AUTH_ENABLED=false
TBANKROT_LOGIN=
TBANKROT_PASSWORD=
TBANKROT_PAGES=3
TBANKROT_INCLUDE_PRICE_SCHEDULE=true
