{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@affino/datagrid-core": ["../datagrid-core/src/index.ts"],
      "@affino/datagrid-core/*": ["../datagrid-core/src/*"],
      "@affino/datagrid-formula-engine": ["../datagrid-formula-engine/src/index.ts"],
      "@affino/datagrid-formula-engine/*": ["../datagrid-formula-engine/src/*"],
      "@affino/datagrid-theme": ["../datagrid-theme/src/index.ts"],
      "@affino/datagrid-theme/*": ["../datagrid-theme/src/*"],
      "@affino/datagrid-pivot": ["../datagrid-pivot/src/index.ts"],
      "@affino/datagrid-pivot/*": ["../datagrid-pivot/src/*"],
      "@affino/datagrid-orchestration": ["../datagrid-orchestration/src/index.ts"],
      "@affino/datagrid-orchestration/*": ["../datagrid-orchestration/src/*"],
      "@affino/datagrid-spreadsheet-vue-app": ["../datagrid-spreadsheet-vue-app/src/index.ts"],
      "@affino/datagrid-spreadsheet-vue-app/*": ["../datagrid-spreadsheet-vue-app/src/*"],
      "@affino/datagrid-vue/app": ["../datagrid-vue/src/app/index.ts"],
      "@affino/datagrid-vue/app/worker": ["../datagrid-vue/src/app/worker.ts"],
      "@affino/datagrid-vue/app/*": ["../datagrid-vue/src/app/*"],
      "@affino/datagrid-vue/advanced": ["../datagrid-vue/src/advanced.ts"],
      "@affino/datagrid-vue": ["../datagrid-vue/src/index.ts"],
      "@affino/datagrid-vue/*": ["../datagrid-vue/src/*"],
      "@affino/datagrid-vue-app": ["../datagrid-vue-app/src/index.ts"],
      "@affino/datagrid-vue-app/internal": ["../datagrid-vue-app/src/internal.ts"],
      "@affino/datagrid-vue-app/*": ["../datagrid-vue-app/src/*"],
      "@affino/datagrid-worker": ["../datagrid-worker/src/index.ts"],
      "@affino/datagrid-worker/*": ["../datagrid-worker/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}
