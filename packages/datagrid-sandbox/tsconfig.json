{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@affino/datagrid-core": ["../datagrid-core/src/index.ts"],
      "@affino/datagrid-core/*": ["../datagrid-core/src/*"],
      "@affino/datagrid-formula-engine": ["../datagrid-formula-engine/src/index.ts"],
      "@affino/datagrid-formula-engine/*": ["../datagrid-formula-engine/src/*"],
      "@affino/datagrid-orchestration": ["../datagrid-orchestration/src/index.ts"],
      "@affino/datagrid-orchestration/*": ["../datagrid-orchestration/src/*"],
      "@affino/datagrid-vue/advanced": ["../datagrid-vue/src/advanced.ts"],
      "@affino/datagrid-vue": ["../datagrid-vue/src/index.ts"],
      "@affino/datagrid-vue/*": ["../datagrid-vue/src/*"],
      "@affino/datagrid-worker": ["../datagrid-worker/src/index.ts"],
      "@affino/datagrid-worker/*": ["../datagrid-worker/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}