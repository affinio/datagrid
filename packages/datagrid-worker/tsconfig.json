{
  "extends": "../../tsconfig.core.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "moduleResolution": "bundler",
    "paths": {
      "@affino/datagrid-core": ["../datagrid-core/dist/src/index.d.ts"],
      "@affino/datagrid-core/*": ["../datagrid-core/dist/src/*"],
      "@affino/datagrid-formula-engine": ["../datagrid-formula-engine/dist/index.d.ts"],
      "@affino/datagrid-formula-engine/*": ["../datagrid-formula-engine/dist/*"]
    },
    "noUncheckedIndexedAccess": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
