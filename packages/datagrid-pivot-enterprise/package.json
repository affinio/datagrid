{
  "name": "@affino/datagrid-pivot-enterprise",
  "version": "0.1.0",
  "author": "Anton Pavlov <a.pavlov@affino.dev>",
  "type": "module",
  "description": "Enterprise pivot runtime extensions for Affino DataGrid",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
