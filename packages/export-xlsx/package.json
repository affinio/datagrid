{
  "name": "@affino/export-xlsx",
  "version": "0.1.0",
  "author": "Anton Pavlov <a.pavlov@affino.dev>",
  "type": "module",
  "description": "Minimal XLSX writer package for Affino exports",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "demo:generate": "pnpm run build && node ./scripts/generate-demo.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/affinio/affinio.git",
    "directory": "packages/export-xlsx"
  },
  "homepage": "https://github.com/affinio/affinio/tree/main/packages/export-xlsx#readme",
  "license": "MIT",
  "keywords": [
    "xlsx",
    "excel",
    "export",
    "writer"
  ],
  "bugs": {
    "url": "https://github.com/affinio/affinio/issues"
  },
  "module": "dist/index.js"
}
