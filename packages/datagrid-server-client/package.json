{
  "name": "@affino/datagrid-server-client",
  "version": "0.1.0",
  "author": "Anton Pavlov <a.pavlov@affino.dev>",
  "type": "module",
  "description": "Reusable server datasource client helpers for Affino DataGrid",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "module": "dist/src/index.js",
  "files": [
    "dist"
  ],
  "sideEffects": false,
