{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": true,
    "paths": {
      "@affino/datagrid-core": ["../datagrid-core/dist/src/index.d.ts"],
      "@affino/datagrid-core/*": ["../datagrid-core/dist/src/*"],
      "@affino/datagrid-server-client": ["../datagrid-server-client/dist/src/index.d.ts"],
      "@affino/datagrid-server-client/*": ["../datagrid-server-client/dist/src/*"]
    }
  }
}
