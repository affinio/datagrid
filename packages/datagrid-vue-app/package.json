{
  "name": "@affino/datagrid-vue-app",
  "version": "0.1.5",
  "description": "Declarative Vue DataGrid component for Affino",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gantt": {
      "types": "./dist/gantt.d.ts",
      "import": "./dist/gantt.js"
    },
    "./advanced-filter": {
      "types": "./dist/advanced-filter.d.ts",
      "import": "./dist/advanced-filter.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @affino/datagrid-chrome build && pnpm --filter @affino/datagrid-gantt build && pnpm --filter @affino/datagrid-vue build && vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist",
    "type-check": "pnpm --filter @affino/datagrid-chrome build && pnpm --filter @affino/datagrid-gantt build && pnpm --filter @affino/datagrid-vue build && vue-tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run --config vitest.config.ts --passWithNoTests",
    "test": "pnpm run type-check && pnpm run test:unit"
  },
  "dependencies": {
    "@affino/datagrid-chrome": "workspace:*",
    "@affino/datagrid-gantt": "workspace:*",
    "@affino/datagrid-theme": "workspace:*",
    "@affino/datagrid-vue": "workspace:*",
    "@affino/menu-vue": "^2.1.1",
    "@affino/popover-vue": "^1.1.0"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/affinio/affinio.git",
    "directory": "packages/datagrid-vue-app"
  },
  "homepage": "https://github.com/affinio/affinio/tree/main/packages/datagrid-vue-app#readme",
  "bugs": {
    "url": "https://github.com/affinio/affinio/issues"
  },
  "keywords": [
    "datagrid",
    "vue",
    "app",
    "declarative"
  ]
}
